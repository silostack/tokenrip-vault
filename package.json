{
  "name": "tokenrip-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:cli": "bun run --filter @tokenrip/cli build",
    "build:backend": "bun run --filter tokenrip-backend build",
    "build:frontend": "bun run --filter tokenrip-frontend build",
    "build:all": "bun run build:cli && bun run build:backend && bun run build:frontend"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "dotenv": "^16.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
